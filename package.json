{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@sprintflow/domain": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "type": "module",
  "name": "sprintflow-mcp",
  "version": "1.0.0",
  "description": "",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",

    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:logs": "docker compose logs -f postgres",
    "docker:psql": "docker exec -it sprintflow-db psql -U postgres -d sprintflow",

    "dev:setup": "npm run docker:up && npm run db:migrate",

    "build:domain": "npm run build -w @sprintflow/domain"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PraneethBunny123/SprintFlow-MCP.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PraneethBunny123/SprintFlow-MCP/issues"
  },
  "homepage": "https://github.com/PraneethBunny123/SprintFlow-MCP#readme"
}
